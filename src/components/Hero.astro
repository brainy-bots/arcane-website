---
import ConstellationLogo from "./ConstellationLogo.astro";
---

<section class="relative overflow-hidden">
  <div class="absolute inset-0 grid-overlay pointer-events-none"></div>

  <div class="relative max-w-7xl mx-auto px-6 md:px-10 pt-16 md:pt-24 pb-24 md:pb-32">
    <!-- Eyebrow label -->
    <div class="flex items-center gap-3 reveal reveal-1">
      <span class="label">§ 00 · MULTIPLAYER BACKEND · v0.1</span>
    </div>

    <!-- MASSIVE brand wordmark + static constellation mark -->
    <div class="mt-10 md:mt-14 flex items-center gap-4 md:gap-8 reveal reveal-2">
      <h1
        class="font-medium leading-[0.85] tracking-[-0.045em] arcane-title"
        style="font-size: clamp(4.5rem, 18vw, 16rem);"
      >{"ARCANE".split("").map((char, i) => (
          <span class="arcane-letter" style={`--letter-i: ${i}`}>{char}</span>
        ))}</h1>
      <div
        class="shrink-0"
        style="width: clamp(2.75rem, 9vw, 7.5rem);"
        aria-hidden="true"
      >
        <ConstellationLogo />
      </div>
    </div>

    <!-- Thin rule below wordmark -->
    <div class="rule mt-10 md:mt-14 reveal reveal-3"></div>

    <!-- Tagline + benchmark number side by side -->
    <div class="mt-10 md:mt-14 grid md:grid-cols-12 gap-10 md:gap-16 items-start">
      <div class="md:col-span-7 reveal reveal-3">
        <p class="text-2xl sm:text-3xl md:text-4xl lg:text-5xl font-medium leading-[1.05] tracking-tight">
          Authoritative multiplayer,<br />
          <span class="text-[color:var(--color-mute)]">without the</span> server crunch.
        </p>
      </div>

      <div class="md:col-span-5 md:pl-8 md:border-l border-[color:var(--color-rule)] reveal reveal-4">
        <div class="label mb-3">CEILING · AWS c7i.2xlarge</div>
        <div class="font-mono leading-none tracking-tight" style="font-size: clamp(3.5rem, 8vw, 6rem);" data-counter="6000">0</div>
        <div class="label mt-4 leading-relaxed">
          CONCURRENT PLAYERS<br />
          <span class="text-[color:var(--color-signal)]">24×</span> OVER SPACETIMEDB BASELINE
        </div>
      </div>
    </div>

    <!-- CTA buttons -->
    <div class="mt-14 md:mt-20 flex flex-wrap gap-3 reveal reveal-5">
      <a href="#benchmark" class="btn btn-primary">VIEW BENCHMARKS →</a>
      <a href="https://github.com/brainy-bots/arcane" target="_blank" rel="noopener" class="btn">
        GITHUB ↗
      </a>
    </div>
  </div>

  <div class="rule"></div>
</section>

<script>
  // Count-up for the big hero number (respects reduced motion)
  const counter = document.querySelector<HTMLElement>("[data-counter]");
  if (counter) {
    const target = parseInt(counter.dataset.counter || "0", 10);
    const format = (n: number) => n.toLocaleString("en-US");
    const prefersReduced = window.matchMedia("(prefers-reduced-motion: reduce)").matches;

    if (prefersReduced) {
      counter.textContent = format(target);
    } else {
      const duration = 1800;
      const start = performance.now() + 700;

      const tick = (now: number) => {
        const elapsed = now - start;
        if (elapsed < 0) {
          counter.textContent = format(0);
          requestAnimationFrame(tick);
          return;
        }
        const t = Math.min(elapsed / duration, 1);
        const eased = 1 - Math.pow(1 - t, 3);
        counter.textContent = format(Math.round(target * eased));
        if (t < 1) requestAnimationFrame(tick);
      };
      requestAnimationFrame(tick);
    }
  }
</script>
