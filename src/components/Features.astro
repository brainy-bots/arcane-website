---
const features = [
  {
    title: "Affinity clustering",
    body: "Servers own groups of likely-interacting entities, not geographic regions. A learned model groups players by interaction probability — party, guild, proximity, combat history — so dense fights stay inside one cluster's authority with no cross-boundary authority transfers. Spatial proximity is one signal among many, not the partitioning rule.",
  },
  {
    title: "Physics at scale",
    body: "Authoritative Rapier physics on native Rust nodes. Each cluster simulates its own entities — adding clusters adds physics capacity. Combat-grade hit registration, real projectile ballistics, destructible environments. At player counts a single Unreal or Unity dedicated server can't reach.",
  },
  {
    title: "Heterogeneous node tiers",
    body: "Pay for physics where it matters. Logic-only nodes for ambient NPCs, Rapier nodes for mid-tier combat, Unreal or Unity dedicated-server nodes for players. All coexist in one deployment — cost scales with simulation complexity, not uniformly across everything.",
  },
  {
    title: "SpacetimeDB persistence",
    body: "Batch-persist to SpacetimeDB at 1 Hz regardless of player count. SpacetimeDB handles durable state and discrete game events; Arcane handles high-frequency position distribution. The database stays essentially idle even at 6,000 players.",
  },
  {
    title: "Unreal Engine plugin",
    body: "Drop arcane-client-unreal into your Plugins/ folder. HTTP join, WebSocket upgrade, replicated entities out of the box. Engine-agnostic wire protocol — Unity and Godot clients speak the same protocol.",
  },
  {
    title: "Open source, reproducible",
    body: "MIT-licensed Rust library. Every benchmark number on this page — hardware, parameters, pass criteria — can be reproduced from a public repo. SpacetimeDB-only, 2-cluster, 4-cluster.",
  },
];
---

<section id="features" class="relative">
  <div class="max-w-7xl mx-auto px-6 md:px-10 py-24 md:py-32">
    <div class="flex items-baseline justify-between mb-16 md:mb-24">
      <h2 class="label m-0">§ 01 / FEATURES</h2>
      <div class="label hidden md:block" aria-hidden="true">/ 06</div>
    </div>

    <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-px bg-[color:var(--color-rule)] border border-[color:var(--color-rule)]">
      {features.map((f, i) => (
        <div class="bg-[color:var(--color-bg)] p-8 md:p-10 min-h-[240px] flex flex-col">
          <div class="label mb-6">{String(i + 1).padStart(2, "0")}</div>
          <h3 class="text-xl md:text-2xl font-medium tracking-tight mb-3">{f.title}</h3>
          <p class="text-[color:var(--color-mute)] text-sm md:text-base leading-relaxed mt-auto">
            {f.body}
          </p>
        </div>
      ))}
    </div>
  </div>

  <div class="rule"></div>
</section>
