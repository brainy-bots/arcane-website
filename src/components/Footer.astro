---
const year = new Date().getFullYear();
---

<footer>
  <div class="max-w-7xl mx-auto px-6 md:px-10 py-10 flex flex-wrap items-baseline justify-between gap-4">
    <div class="flex items-center gap-3">
      <span class="signal-dot"></span>
      <span class="label">ARCANE · {year}</span>
    </div>
    <div class="flex flex-wrap gap-6 label">
      <a href="https://github.com/brainy-bots/arcane" class="hover:text-[color:var(--color-signal)] transition-colors">LIBRARY</a>
      <a href="https://github.com/brainy-bots/arcane-demos" class="hover:text-[color:var(--color-signal)] transition-colors">DEMOS</a>
      <a href="https://github.com/brainy-bots/arcane-scaling-benchmarks" class="hover:text-[color:var(--color-signal)] transition-colors">BENCHMARKS</a>
      <span>MIT LICENSED</span>
    </div>
  </div>
</footer>
